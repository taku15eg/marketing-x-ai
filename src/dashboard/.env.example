# Publish Gate - Environment Variables
# Copy this to .env.local and fill in your values

# REQUIRED: Anthropic API Key (server-side only)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OPTIONAL: Screenshot API Key (for Vision API analysis)
SCREENSHOT_API_KEY=

# RECOMMENDED: Supabase (for persistent storage of analyses and share URLs)
# Without these, data is stored in-memory and lost on restart.
# Run supabase/migrations/20260314_001_create_analyses_and_shares.sql first.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
