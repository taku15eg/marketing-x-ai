# Publish Gate - 環境変数テンプレート
# このファイルを .env.local にコピーして値を設定してください
#
#   cp .env.example src/dashboard/.env.local
#
# 詳細は src/dashboard/.env.example も参照

# REQUIRED: Anthropic API Key (サーバーサイド専用)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OPTIONAL: Screenshot API Key (Vision API分析用)
SCREENSHOT_API_KEY=

# OPTIONAL: Supabase (Phase 1+)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
